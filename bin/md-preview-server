#!/usr/bin/env python3
from __future__ import annotations

import argparse
import html
from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer
from pathlib import Path


STYLE = """
body {
  margin: 0;
  background: #f7f8fa;
  color: #24292f;
  font: 15px/1.55 -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}
main {
  max-width: 1120px;
  margin: 0 auto;
  padding: 32px 40px 80px;
  background: #fff;
  min-height: 100vh;
  box-sizing: border-box;
}
h1, h2, h3 {
  line-height: 1.25;
  margin: 1.5em 0 .6em;
}
h1 { font-size: 2rem; border-bottom: 1px solid #d8dee4; padding-bottom: .35em; }
h2 { font-size: 1.45rem; border-bottom: 1px solid #d8dee4; padding-bottom: .25em; }
h3 { font-size: 1.15rem; }
code {
  background: #f0f2f4;
  border-radius: 4px;
  padding: .12em .35em;
  font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
  font-size: .92em;
}
pre {
  background: #f6f8fa;
  border: 1px solid #d8dee4;
  border-radius: 6px;
  overflow: auto;
  padding: 14px 16px;
}
pre code { background: transparent; padding: 0; }
table {
  border-collapse: collapse;
  width: max-content;
  max-width: 100%;
  margin: 1em 0;
  display: block;
  overflow-x: auto;
}
th, td {
  border: 1px solid #d0d7de;
  padding: 6px 10px;
  white-space: nowrap;
}
th { background: #f6f8fa; font-weight: 600; }
blockquote {
  border-left: 4px solid #d0d7de;
  color: #57606a;
  padding-left: 1em;
  margin-left: 0;
}
.meta {
  color: #57606a;
  font-size: 13px;
  margin-bottom: 20px;
}
"""


class Handler(BaseHTTPRequestHandler):
    md = None
    file_path: Path

    def do_GET(self) -> None:
        if self.path not in {"/", "/index.html"}:
            self.send_error(404)
            return
        try:
            text = self.file_path.read_text(encoding="utf-8")
            rendered = self.md.render(text)
            body = (
                "<!doctype html><html><head><meta charset='utf-8'>"
                "<meta name='viewport' content='width=device-width, initial-scale=1'>"
                "<meta http-equiv='refresh' content='2'>"
                f"<title>{html.escape(self.file_path.name)}</title>"
                f"<style>{STYLE}</style></head><body><main>"
                f"<div class='meta'>{html.escape(str(self.file_path))}</div>"
                f"{rendered}</main></body></html>"
            )
            payload = body.encode("utf-8")
        except Exception as exc:
            self.send_error(500, explain=str(exc))
            return
        self.send_response(200)
        self.send_header("Content-Type", "text/html; charset=utf-8")
        self.send_header("Content-Length", str(len(payload)))
        self.end_headers()
        self.wfile.write(payload)

    def log_message(self, fmt: str, *args: object) -> None:
        print(f"{self.address_string()} - {fmt % args}", flush=True)


def main() -> None:
    parser = argparse.ArgumentParser()
    parser.add_argument("file", type=Path)
    parser.add_argument("--host", default="127.0.0.1")
    parser.add_argument("--port", type=int, default=8090)
    args = parser.parse_args()

    try:
        from markdown_it import MarkdownIt
    except ModuleNotFoundError:
        parser.error("missing Python module 'markdown_it' (install package 'markdown-it-py')")

    Handler.md = MarkdownIt("commonmark").enable("table").enable("strikethrough")
    Handler.file_path = args.file.resolve()
    server = ThreadingHTTPServer((args.host, args.port), Handler)
    print(f"Serving {Handler.file_path} at http://{args.host}:{args.port}", flush=True)
    server.serve_forever()


if __name__ == "__main__":
    main()
